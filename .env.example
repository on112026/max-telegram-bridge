# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Telegram user id, которому разрешено общаться с ботом (через запятую)
ALLOWED_TG_USER_IDS=

# --- MAX credentials (web) ---
MAX_PHONE=+79000000000
MAX_PASSWORD=
# TOTP secret для 2FA (опционально). Если не указан и потребуется код — бот запросит его у владельца.
MAX_TOTP_SECRET=
# URL веб-версии MAX. По умолчанию используется известный домен web-клиента MAX.
MAX_WEB_URL=https://web.max.ru

# --- API gateway ---
BRIDGE_API_KEY=
API_HOST=0.0.0.0
API_PORT=8000
DB_PATH=/data/bridge.db
MEDIA_DIR=/data/media
PROFILE_DIR=/data/max-profile

# --- Watcher ---
WATCHER_POLL_INTERVAL=1.5
WATCHER_HEALTH_INTERVAL=30
WATCHER_HISTORY_BACKFILL=50
# Watcher в headful-режиме по умолчанию (1 = да). Имеет смысл только при
# наличии DISPLAY (Xvfb) — Railway-деплой всегда с Xvfb, поэтому в проде
# оставьте 0 и включайте headful через Telegram-кнопку /reauth.
WATCHER_HEADFUL_DEFAULT=0

# --- Headful / VNC (ручная авторизация через Telegram или браузер) ---
# Пароль для VNC-подключения к Chromium (виртуальному дисплею Xvfb).
# Используется и для noVNC-страницы /vnc, и для прямого VNC-клиента.
# Если пусто — сгенерируется случайный и выведется в лог supervisord
# при первом запуске (НЕ оставляйте пустым в проде).
VNC_PASSWORD=changeme
# Разрешить публичный доступ к noVNC по адресу <railway>/vnc.
# 1 = включено, 0 = страница отдаёт 404. noVNC защищён только VNC-паролем.
VNC_PUBLIC=1
# Порт noVNC внутри контейнера (обычно 6080). Менять не нужно.
NOVNC_PORT=6080

# --- Logging ---
LOG_LEVEL=INFO